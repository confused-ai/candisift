# Copy to .env and edit. All app settings use the CANDISIFT_ prefix (see candisift/config.py).

# --- LLM (omit to run the deterministic offline stub — no cost, good for demo/tests) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- model tiers (any provider Agno supports: claude-*, gpt-*, gemini-*, llama-*).
#     Set that provider's own key too (ANTHROPIC_API_KEY / OPENAI_API_KEY / ...). ---
CANDISIFT_PERSONA_MODEL=claude-haiku-4-5
CANDISIFT_SYNTH_MODEL=claude-opus-4-8

# --- LOCAL MODELS via Ollama (fully offline, $0/token) ---------------------------
# 1. install + start Ollama:  brew install ollama && ollama serve   (or run the app)
# 2. pull models:             ollama pull llama3.1 && ollama pull qwen2.5
# 3. tell the ATS the python client is present:  pip install ollama
# 4. point the tiers at "ollama/<model>" (the prefix routes to the local server;
#    no API key needed). Mix freely — e.g. local personas + a hosted synth:
# CANDISIFT_PERSONA_MODEL=ollama/llama3.1
# CANDISIFT_SYNTH_MODEL=ollama/qwen2.5
# OLLAMA_HOST=http://localhost:11434   # only if not the default host/port
# OLLAMA_API_KEY=                      # only for Ollama Cloud, not a local server

# --- ANY OpenAI-COMPATIBLE endpoint (DeepInfra, Together, OpenRouter, Fireworks,
#     vLLM, LM Studio, ...) -----------------------------------------------------
# They all speak the OpenAI wire format, so one mechanism covers them: prefix the
# model id with "openai/" and set OPENAI_BASE_URL + OPENAI_API_KEY.  (pip install openai)
# Example — DeepInfra:
# OPENAI_BASE_URL=https://api.deepinfra.com/v1/openai
# OPENAI_API_KEY=<your-deepinfra-token>     # any non-empty value for keyless local servers
# CANDISIFT_PERSONA_MODEL=openai/meta-llama/Meta-Llama-3.1-8B-Instruct
# CANDISIFT_SYNTH_MODEL=openai/meta-llama/Meta-Llama-3.1-70B-Instruct
#   (Together: https://api.together.xyz/v1 · OpenRouter: https://openrouter.ai/api/v1
#    · vLLM/LM Studio: http://localhost:8000/v1 etc.)

# --- ANY ANTHROPIC-COMPATIBLE endpoint (a Claude-API gateway/proxy) ------------
# The Anthropic SDK honours ANTHROPIC_BASE_URL natively, so keep a claude-* model
# id and just point it at the gateway:
# ANTHROPIC_BASE_URL=https://your-anthropic-gateway/v1
# ANTHROPIC_API_KEY=<gateway-token>

# --- LLM throttling (provider-side; separate from the HTTP rate limit) ---
# For local Ollama, set CONCURRENCY/RATE to what your GPU can sustain (it has no
# provider rate limit — the bottleneck is your own hardware).
CANDISIFT_LLM_MAX_CONCURRENCY=4    # max simultaneous in-flight LLM calls
CANDISIFT_LLM_RATE_PER_MIN=60      # token-bucket cap on LLM calls/minute

# --- cost knobs ---
CANDISIFT_HR_EVAL_ENABLED=true        # false drops the advisory HR people-fit call (~1/4 of per-screen persona cost)
CANDISIFT_COVERAGE_AUDIT_ENABLED=true # false skips the §5 QA second-opinion call

# --- persistence ---
# Prod: use Postgres — `pip install "psycopg[binary]"`, then point DB_URL at it.
# The engine auto-enables pool_pre_ping + pooled connections for server DBs.
# CANDISIFT_DB_URL=postgresql+psycopg://user:pass@host:5432/candisift
# CANDISIFT_DB_URL=sqlite:///candisift.db
CANDISIFT_DB_URL=sqlite+libsql:///candisift.db

# --- funnel ---
CANDISIFT_MAX_ATTEMPTS=3
CANDISIFT_WORKER_LEASE_SECONDS=600
CANDISIFT_WORKER_CONCURRENCY=3     # parallel worker threads; raise to screen a batch faster

# --- OCR (scanned PDFs / image resumes). Needs system bins: tesseract + poppler ---
CANDISIFT_OCR_ENABLED=true
CANDISIFT_OCR_LANG=eng            # e.g. eng+deu for multilingual
CANDISIFT_OCR_DPI=300
CANDISIFT_OCR_MAX_PAGES=5        # cap pages rendered+OCR'd per PDF
CANDISIFT_OCR_TIMEOUT_S=300        # per-call cap on tesseract/poppler

# --- recruiter UI auth (CHANGE THESE; prod refuses to boot on the default password) ---
CANDISIFT_BASIC_AUTH_USER=recruiter
CANDISIFT_BASIC_AUTH_PASS=change-me

# --- security / limits ---
CANDISIFT_ENV=dev                 # set to "prod" to enforce secret hardening
CANDISIFT_MAX_FILE_MB=5
CANDISIFT_MAX_FILES_PER_BATCH=200
CANDISIFT_MAX_REQUEST_MB=64
CANDISIFT_RATE_LIMIT_PER_MIN=120
# Number of trusted reverse proxies / load balancers in front of the app.
# 0 = direct exposure: X-Forwarded-For is ignored (clients can forge it).
# >0 = the rate limiter reads the client IP from the Nth XFF entry counted from the
# RIGHT (the entries your own hops appended). Set it to your real hop count: leaving
# it 0 behind a proxy puts every user in one shared bucket (one abuser 429s everyone);
# setting it too high trusts a forged entry. e.g. 1 = one nginx/ALB in front.
CANDISIFT_TRUSTED_PROXY_COUNT=0
CANDISIFT_CORS_ORIGINS=           # comma-separated allowlist; empty = same-origin only
CANDISIFT_HSTS=false              # set true only behind HTTPS
